rules_version = '2';

// Firestore security rules for PintPal.
// Style: helper functions + clear sections (same pattern as larger admin apps).
// users/{uid} document ID must equal the authenticated Auth UID.
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // AUTH / USER HELPERS
    // ============================================================

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function currentUserExists() {
      return signedIn() && exists(currentUserPath());
    }

    function currentUser() {
      return currentUserExists() ? get(currentUserPath()).data : null;
    }

    function userRoleLower() {
      return !currentUserExists()
        ? ''
        : (currentUser().role is string ? currentUser().role.lower() : '');
    }

    // Admin: canViewAdmin flag or role == admin (set only via console / Admin SDK).
    function isAdmin() {
      return signedIn() && currentUserExists() && (
        currentUser().canViewAdmin == true
        || userRoleLower() == 'admin'
      );
    }

    // Subscription: true == paid, false == free.
    // Admins are always treated as paid. Regular users are free unless
    // subscriptionPaid was set to true by an admin / backend.
    function isSubscriptionPaid() {
      return isAdmin()
        || (currentUserExists() && currentUser().subscriptionPaid == true);
    }

    function freePhotoDailyLimit() {
      return 2;
    }

    // ============================================================
    // USERS
    // ============================================================

    match /users/{userId} {
      // Owner and admins can read.
      allow read: if isOwner(userId) || isAdmin();

      // First-time registration: own doc only; cannot self-grant admin or paid.
      allow create: if isOwner(userId)
        && request.resource.data.email is string
        && request.resource.data.name is string
        && request.resource.data.role == 'user'
        && request.resource.data.canLogin == true
        && request.resource.data.canViewAdmin == false
        && request.resource.data.subscriptionPaid == false
        && (
          !('photoUploadsToday' in request.resource.data)
          || request.resource.data.photoUploadsToday == 0
        );

      // Owners may update profile fields but cannot escalate privileged flags.
      // Admins may update any user (including subscriptionPaid).
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.canViewAdmin == resource.data.canViewAdmin
          && request.resource.data.get('subscriptionPaid', false)
            == resource.data.get('subscriptionPaid', false)
          && request.resource.data.canLogin == resource.data.canLogin
        );

      allow delete: if isAdmin();
    }

    // ============================================================
    // POUR THE PERFECT PINT SCORES
    // Separate from ratings / contribution leaderboards.
    // ============================================================

    match /pour_game_scores/{scoreId} {
      allow read: if resource.data.isPublic == true
        || (signedIn() && resource.data.userId == request.auth.uid)
        || isAdmin();

      allow create, update: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.mode in ['practice', 'timed']
        && request.resource.data.score is number;

      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ============================================================
    // SERVING RUSH SCORES
    // Separate from pour scores and ratings boards.
    // ============================================================

    match /serving_game_scores/{scoreId} {
      allow read: if resource.data.isPublic == true
        || (signedIn() && resource.data.userId == request.auth.uid)
        || isAdmin();

      allow create, update: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.score is number;

      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ============================================================
    // BEST PINTS PHOTO CONTEST
    // Upload photos, rate 1–10, daily leaders, weekly top-3 vote.
    // ============================================================

    match /pint_photos/{photoId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.imageUrl is string
        && request.resource.data.storagePath is string
        && request.resource.data.dayKey is string
        && request.resource.data.weekKey is string
        && request.resource.data.ratingSum == 0
        && request.resource.data.ratingCount == 0
        && request.resource.data.averageRating == 0;

      // Owner may delete own photo. Rating aggregates updated with a score write.
      allow update: if signedIn() && (
        isAdmin()
        || (
          resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.imageUrl == resource.data.imageUrl
          && request.resource.data.storagePath == resource.data.storagePath
        )
        || (
          request.resource.data.userId == resource.data.userId
          && request.resource.data.imageUrl == resource.data.imageUrl
          && request.resource.data.storagePath == resource.data.storagePath
          && request.resource.data.dayKey == resource.data.dayKey
          && request.resource.data.weekKey == resource.data.weekKey
          && request.resource.data.ratingCount is number
          && request.resource.data.ratingSum is number
          && request.resource.data.averageRating is number
          && (
            request.resource.data.ratingCount == resource.data.ratingCount + 1
            || request.resource.data.ratingCount == resource.data.ratingCount
          )
        )
      );

      allow delete: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      match /ratings/{raterUid} {
        allow read: if signedIn();
        allow create, update: if signedIn()
          && request.auth.uid == raterUid
          && request.resource.data.score is number
          && request.resource.data.score >= 1
          && request.resource.data.score <= 10;
        allow delete: if signedIn() && request.auth.uid == raterUid;
      }
    }

    match /contest_weeks/{weekKey} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.finalistIds is list
        && request.resource.data.finalistIds.size() <= 3
        && request.resource.data.status in ['open', 'finalists', 'voting', 'closed'];
      allow delete: if isAdmin();

      match /votes/{voterUid} {
        allow read: if signedIn();
        allow create, update: if signedIn()
          && request.auth.uid == voterUid
          && request.resource.data.photoId is string;
        allow delete: if signedIn() && request.auth.uid == voterUid;
      }
    }

    match /contest_days/{dayKey} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.winnerId is string;
      allow delete: if isAdmin();
    }

    // ============================================================
    // DRINK / BEER MIX RATINGS
    // e.g. "Heineken with lemon" — rate 1–10; similar by base/tags.
    // ============================================================

    match /drink_entries/{drinkId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.baseBeer is string
        && request.resource.data.ratingSum == 0
        && request.resource.data.ratingCount == 0
        && request.resource.data.averageRating == 0;

      allow update: if signedIn() && (
        isAdmin()
        || (
          resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
        )
        || (
          request.resource.data.userId == resource.data.userId
          && request.resource.data.title == resource.data.title
          && request.resource.data.baseBeer == resource.data.baseBeer
          && request.resource.data.ratingCount is number
          && request.resource.data.ratingSum is number
          && request.resource.data.averageRating is number
          && (
            request.resource.data.ratingCount == resource.data.ratingCount + 1
            || request.resource.data.ratingCount == resource.data.ratingCount
          )
        )
      );

      allow delete: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      match /ratings/{raterUid} {
        allow read: if signedIn();
        allow create, update: if signedIn()
          && request.auth.uid == raterUid
          && request.resource.data.score is number
          && request.resource.data.score >= 1
          && request.resource.data.score <= 10;
        allow delete: if signedIn() && request.auth.uid == raterUid;
      }
    }

    // ============================================================
    // DEFAULT DENY
    // ============================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
