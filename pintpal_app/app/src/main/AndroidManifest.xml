<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Pintpal">
        <activity
            android:name=".features.auth.ui.AuthLoginActivity"
            android:exported="true"
            android:label="@string/auth_login_title"
            android:theme="@style/Theme.Pintpal">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".features.auth.ui.AuthRegisterActivity"
            android:exported="false"
            android:label="@string/auth_register_title"
            android:theme="@style/Theme.Pintpal"
            android:parentActivityName=".features.auth.ui.AuthLoginActivity" />
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:resizeableActivity="true"
            android:theme="@style/Theme.Pintpal.NoActionBar"
            tools:targetApi="24" />
        <activity
            android:name=".features.games_common.ui.GamesCommonDemoActivity"
            android:exported="false"
            android:label="@string/games_common_demo_title"
            android:theme="@style/Theme.Pintpal" />
        <activity
            android:name=".features.pour_game.ui.PourGameHubActivity"
            android:exported="false"
            android:label="@string/pour_game_title"
            android:theme="@style/Theme.Pintpal" />
        <activity
            android:name=".features.pour_game.ui.PourPracticeActivity"
            android:exported="false"
            android:label="@string/pour_game_title"
            android:theme="@style/Theme.Pintpal"
            android:parentActivityName=".features.pour_game.ui.PourGameHubActivity" />
        <activity
            android:name=".features.pour_game.ui.PourTimedActivity"
            android:exported="false"
            android:label="@string/pour_game_timed_title"
            android:theme="@style/Theme.Pintpal"
            android:parentActivityName=".features.pour_game.ui.PourGameHubActivity" />
        <activity
            android:name=".features.pour_game.ui.PourScoreboardActivity"
            android:exported="false"
            android:label="@string/pour_game_scoreboard_title"
            android:theme="@style/Theme.Pintpal"
            android:parentActivityName=".features.pour_game.ui.PourGameHubActivity" />
    </application>

</manifest>
