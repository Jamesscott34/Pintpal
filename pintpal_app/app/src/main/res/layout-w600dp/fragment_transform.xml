<?xml version="1.0" encoding="utf-8"?>
<!-- Tablet/wide: same Profile tab content as phone. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/games_common_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_shell_private_eyebrow"
            android:textAllCaps="true"
            android:textColor="@color/games_common_accent"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_shell_private_title"
            android:textColor="@color/games_common_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/profile_tab_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/games_common_muted" />

        <Button
            android:id="@+id/profile_tab_best_pints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/menu_best_pints" />

        <Button
            android:id="@+id/profile_tab_full_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_shell_private_title" />

        <Button
            android:id="@+id/profile_tab_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/admin_dashboard_title"
            android:visibility="gone" />

        <Button
            android:id="@+id/profile_tab_sign_out"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/auth_sign_out" />
    </LinearLayout>
</ScrollView>
