<?xml version="1.0" encoding="utf-8"?>
<!-- Scoreboard tab (was Slideshow): game boards + Best Pints so far. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/games_common_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/scoreboard_hub_title"
            android:textColor="@color/games_common_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/scoreboard_hub_lead"
            android:textColor="@color/games_common_muted" />

        <Button
            android:id="@+id/scoreboard_tab_pour"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/scoreboard_open_pour" />

        <Button
            android:id="@+id/scoreboard_tab_serving"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/scoreboard_open_serving" />

        <Button
            android:id="@+id/scoreboard_tab_best_pints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/scoreboard_open_best_pints" />
    </LinearLayout>
</ScrollView>
