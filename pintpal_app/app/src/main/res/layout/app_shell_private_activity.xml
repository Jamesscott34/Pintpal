<?xml version="1.0" encoding="utf-8"?>
<!--
  app_shell_private_activity.xml
  Purpose: Private section — friendly profile; admin details only for admins.
  Connects to: PrivateProfileActivity.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/games_common_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_shell_private_eyebrow"
            android:textAllCaps="true"
            android:textColor="@color/games_common_accent"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_shell_private_title"
            android:textColor="@color/games_common_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/app_shell_private_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/games_common_muted" />

        <TextView
            android:id="@+id/app_shell_private_admin_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/games_common_accent"
            android:visibility="gone" />

        <Button
            android:id="@+id/app_shell_open_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/admin_dashboard_title"
            android:visibility="gone" />

        <Button
            android:id="@+id/app_shell_open_public"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/app_shell_public_title" />

        <Button
            android:id="@+id/app_shell_sign_out"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/auth_sign_out" />
    </LinearLayout>
</ScrollView>
