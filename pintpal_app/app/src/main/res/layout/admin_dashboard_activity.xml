<?xml version="1.0" encoding="utf-8"?>
<!--
  admin_dashboard_activity.xml
  Purpose: Admin dashboard — user list + community shortcuts.
  Connects to: AdminDashboardActivity.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/games_common_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_eyebrow"
            android:textAllCaps="true"
            android:textColor="@color/games_common_accent"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/admin_dashboard_title"
            android:textColor="@color/games_common_text"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/admin_dashboard_lead"
            android:textColor="@color/games_common_muted" />

        <Button
            android:id="@+id/admin_open_games"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/menu_pour_game" />

        <Button
            android:id="@+id/admin_open_scoreboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pour_game_scoreboard_title" />

        <Button
            android:id="@+id/admin_open_public"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_shell_public_title" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="@string/admin_all_users"
            android:textColor="@color/games_common_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/admin_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/games_common_muted"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/admin_users_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
