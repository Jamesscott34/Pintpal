<?xml version="1.0" encoding="utf-8"?>
<!--
  pour_game_timed_activity.xml
  Purpose: Timed multi-pour run UI (30/60/90/120s).
  Connects to: PourTimedActivity.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/games_common_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pour_game_timed_title"
            android:textColor="@color/games_common_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/pour_game_timed_sub"
            android:textColor="@color/games_common_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/pour_game_timed_setup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="vertical">

            <RadioGroup
                android:id="@+id/pour_game_duration_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/pour_game_dur_30"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30s"
                    android:textColor="@color/games_common_text" />

                <RadioButton
                    android:id="@+id/pour_game_dur_60"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="60s"
                    android:textColor="@color/games_common_text" />

                <RadioButton
                    android:id="@+id/pour_game_dur_90"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="90s"
                    android:textColor="@color/games_common_text" />

                <RadioButton
                    android:id="@+id/pour_game_dur_120"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="120s"
                    android:textColor="@color/games_common_text" />
            </RadioGroup>

            <Button
                android:id="@+id/pour_game_start_timed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/pour_game_start_timed" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/pour_game_timed_run"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/pour_game_clock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/games_common_accent"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pour_game_timed_hud"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/games_common_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/pour_game_timed_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/games_common_muted"
                android:textSize="13sp" />

            <com.jdscott.pintpal.features.games_common.ui.PourGlassView
                android:id="@+id/pour_game_timed_glass"
                android:layout_width="180dp"
                android:layout_height="260dp"
                android:layout_marginTop="12dp"
                android:contentDescription="@string/games_common_glass_cd" />

            <Button
                android:id="@+id/pour_game_timed_pour"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:minWidth="200dp"
                android:text="@string/pour_game_hold_to_pour" />

            <TextView
                android:id="@+id/pour_game_timed_finished"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textColor="@color/games_common_text"
                android:textSize="16sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/pour_game_new_timed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/pour_game_new_timed"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
