rules_version = '2';

// Firebase Storage rules for PintPal.
// User uploads live under users/{uid}/… and must match the authenticated Auth UID.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isImageUnder10mb() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Profile / account media: users/{uid}/profile/**
    match /users/{userId}/profile/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isImageUnder10mb();
      allow delete: if isOwner(userId);
    }

    // Drink / review photos: users/{uid}/uploads/**
    match /users/{userId}/uploads/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isImageUnder10mb();
      allow delete: if isOwner(userId);
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
